REINFOLIB_API_KEY=
DATABASE_URL=sqlite:///../data/reinfolib.db
REINFOLIB_BASE_URL=https://www.reinfolib.mlit.go.jp/ex-api/external
SYNC_SLEEP_SECONDS=0.5
# e-Stat 政府統計API（https://www.e-stat.go.jp/api/ で無料appId取得）
ESTAT_APP_ID=
ESTAT_BASE_URL=https://api.e-stat.go.jp/rest/3.0/app/json
# 本番の canonical / sitemap / OG 用
SITE_URL=https://fudosan-database.jp
# Google Search Console 所有権確認（HTMLタグ方式の content 値のみ）
GOOGLE_SITE_VERIFICATION=
# HTMLファイル方式を使う場合（例: google1234abcd.html）
GOOGLE_SITE_VERIFICATION_FILE=
# GoogleニュースRSSキャッシュ（秒）
NEWS_CACHE_TTL_SECONDS=1800
